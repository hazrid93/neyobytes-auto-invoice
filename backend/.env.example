# ─────────────────────────────────────────────────────────────
# Neyobytes Auto Invoice — backend env template
# Copy to .env.local (dev) and .env.prod (production) and fill in.
# Only .env.example is committed; .env.local and .env.prod are gitignored.

# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development            # development | production | test
PORT=4001  # 4000 is occupied by litellm on this host
# Origins allowed to call the API. "*" for dev; comma-separated in prod, e.g.
#   CORS_ORIGIN=https://app.neyobytes.com
CORS_ORIGIN=*

# Supabase — project "auto-invoice" (iivmrhluihdsmgxyhljo)
# Backend uses the service-role key for everything (Auth admin + data + storage).
# The frontend never talks to Supabase, so the publishable/anon key is optional.
SUPABASE_URL=https://iivmrhluihdsmgxyhljo.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx                      # service-role key — bypasses RLS
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx          # only needed for reset-email later

# Backend-issued JWT (HS256) — jemput-style. The frontend authenticates with
# the backend and carries this token; the backend validates it with the secret.
# Generate a secret:  openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_run_openssl_rand_hex_32

# Public app URL — used for email redirects (password reset). Optional.
APP_URL=http://localhost:8081

# Direct Postgres via the Supabase connection pooler (Supavisor) — VERIFIED LIVE.
# Region ap-southeast-1 (Singapore). Include ?sslmode=require.
#   6543 = transaction mode (recommended for web backends; multiplexes well,
#          db.transaction() still pins one connection, prepare=false set in code)
#   5432 = session mode (only if you need prepared statements / LISTEN / advisory locks)
# DATABASE_URL=postgresql://postgres.iivmrhluihdsmgxyhljo:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# ── LLM gateway (litellm) — OpenAI-compatible /v1/chat/completions ──
# The gateway runs locally on this host (litellm.service, port 4000). When you
# expose it publicly as llm1.neyobytes.com (no DNS record yet), point this there.
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=replace_with_litellm_master_key   # LITELLM_MASTER_KEY from the gateway's env
# Vision-capable model for invoice OCR/extraction (probed: accepts image_url).
LLM_VISION_MODEL=kimi-k2.7
# Text-only model, used as fallback for non-vision calls (NOT multimodal).
LLM_TEXT_MODEL=glm-5.2
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=300000

# ── LHDN MyInvois e-Invoicing ──
MYINVOIS_ENV=mock                # mock | sandbox | prod  (mock = no real API calls)
MYINVOIS_CLIENT_ID=              # required for sandbox/prod, ignored in mock
MYINVOIS_CLIENT_SECRET=          # required for sandbox/prod, ignored in mock
MYINVOIS_CERT_PEM=               # PEM cert for submit (POS Digicert/LHDNM). mock ignores.
MYINVOIS_KEY_PEM=                # PEM private key for submit. mock ignores.

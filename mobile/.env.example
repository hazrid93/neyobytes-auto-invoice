# Frontend env (Expo). Copy to .env.local or .env.prod and adjust.
# EXPO_PUBLIC_* vars are inlined into the bundle at build time (SDK 49+).
#
# Same-origin web deploy: set EMPTY so requests hit /auth /invoices /myinvois
# /health on the deployed origin (nginx proxies them to the backend).
# Local dev against a standalone backend: set to the backend origin.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4001